# NutriSnap Environment Variables
# Copy this file to .env.local and fill in your values

# Supabase Configuration
# Get these from: https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api
EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Google OAuth
# Set up at: https://console.cloud.google.com/apis/credentials
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=your-web-client-id.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=your-android-client-id.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=your-ios-client-id.apps.googleusercontent.com

# Groq API Keys (round-robin rotation)
# Get from: https://console.groq.com/keys
EXPO_PUBLIC_GROQ_API_KEY_1=your-groq-api-key-1
EXPO_PUBLIC_GROQ_API_KEY_2=your-groq-api-key-2
EXPO_PUBLIC_GROQ_API_KEY_3=your-groq-api-key-3

# PostHog Analytics (Optional)
# Get from: https://app.posthog.com/project/settings
EXPO_PUBLIC_POSTHOG_API_KEY=your-posthog-api-key
EXPO_PUBLIC_POSTHOG_HOST=https://app.posthog.com
